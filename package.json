{
  "name": "ceunuvens",
  "version": "0.1.0",
  "private": true,
  "description": "Previsão de mar de nuvens em montanhas, cânions e mirantes do Brasil",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm-run-all build:backend build:frontend",
    "build:backend": "npm --workspace backend run build",
    "build:frontend": "npm --workspace frontend run build",
    "build:og": "node scripts/build-og-image.mjs",
    "test": "npm --workspace backend run test"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "npm-run-all": "^4.1.5"
  }
}
